# =============================================================================
# Backend Environment Configuration
# =============================================================================
# Copy this file to .env for local development (outside Docker).

# Database (MySQL 8)
DATABASE_URL=mysql+aiomysql://myuser:YourPassword123!@127.0.0.1:3306/mydb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Exchange API Keys
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
BYBIT_API_KEY=
BYBIT_API_SECRET=
UPBIT_API_KEY=
UPBIT_API_SECRET=
BITHUMB_API_KEY=
BITHUMB_API_SECRET=

# Trading
TRADING_MODE=paper
TRADING_PAIRS=BTC/USDT,ETH/USDT,XRP/USDT,SOL/USDT
ACTIVE_EXCHANGES=binance,upbit,bithumb

# Risk Management
MAX_POSITION_SIZE=1000.0
MIN_PROFIT_THRESHOLD=0.3
MAX_SLIPPAGE=0.1
DAILY_LOSS_LIMIT=500.0
MAX_CONCURRENT_POSITIONS=5

# Strategy
PRICE_FETCH_INTERVAL=1.0
ORDER_BOOK_DEPTH=10
OPPORTUNITY_EXPIRY=5.0
ENABLE_KIMCHI_PREMIUM=true

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/arbitrage.log
LOG_ROTATION=50 MB
LOG_RETENTION=30 days

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Security
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Frontend
FRONTEND_URL=http://localhost:3000
