# ================================================================
# ArbitrageX - Environment Configuration
# ================================================================
# Copy this file to .env and customize values.
# Required values are marked with [REQUIRED].
# ================================================================

# ---- General ----
APP_NAME=ArbitrageX
APP_ENV=development                # development | staging | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-random-string-in-production

# ---- Backend API ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Frontend ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENABLE_MOCK_FALLBACK=true

# ---- Database (MySQL) ----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=arbitrage
MYSQL_USER=myuser
MYSQL_PASSWORD=YourPassword123!
MYSQL_PORT=3306
DATABASE_URL=mysql+aiomysql://myuser:YourPassword123!@127.0.0.1:3306/arbitrage?charset=utf8mb4

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PORT=6379

# ---- Trading Mode ----
# mock    = Mock exchanges, no real API calls, demo data
# paper   = Full pipeline but no real orders placed
# simulation = Enhanced simulation with orderbook modeling
# live    = REAL orders on REAL exchanges [DANGEROUS]
TRADING_MODE=paper
TRADING_PAPER_MODE=true
ENABLE_MOCK_EXCHANGES=true
ENABLE_LIVE_TRADING=false

# ---- Exchange API Keys (only needed for live mode) ----
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ---- Risk Management ----
RISK_MAX_ORDER_VALUE_USDT=10000
RISK_MAX_POSITION_VALUE_USDT=50000
RISK_MAX_DAILY_LOSS_USDT=500
RISK_MAX_CONSECUTIVE_FAILURES=5
RISK_MAX_SLIPPAGE_PCT=0.15
RISK_MIN_PROFIT_THRESHOLD_PCT=0.05
RISK_MIN_PROFIT_THRESHOLD_USDT=1.0
RISK_MAX_OPEN_ORDERS=10
RISK_COOLDOWN_AFTER_FAILURE_S=30

# ---- Strategy ----
STRATEGY_ENABLED_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT
STRATEGY_SCAN_INTERVAL_MS=500
STRATEGY_MIN_DEPTH_USDT=500
STRATEGY_ORDERBOOK_DEPTH_LEVELS=10
STRATEGY_OPPORTUNITY_TTL_S=5
STRATEGY_EXECUTION_TIMEOUT_S=10

# ---- Alerts ----
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_PASSWORD=
ENABLE_ALERT_NOTIFICATIONS=false

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:80

# ---- Nginx (optional) ----
NGINX_PORT=80
